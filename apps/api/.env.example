# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/akashi_contact?schema=public"

# API
PORT=3000

# Web app URL
APP_URL=http://localhost:5173

# Push notification settings
# Generate keys with:
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:test@example.com

# Email notification settings
# If SMTP_HOST is empty, the app uses mock email sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="明石高専連絡ポータル <example@gmail.com>"
